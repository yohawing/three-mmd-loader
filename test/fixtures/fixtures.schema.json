{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./fixtures.schema.json",
  "title": "three-mmd-loader fixture inventory",
  "description": "Inventory of fixture files used by three-mmd-loader smoke checks.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "paths"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional JSON Schema URI for editor tooling."
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "Fixture inventory schema version."
    },
    "basePath": {
      "type": "string",
      "default": ".",
      "description": "Base directory for fixture entries, resolved relative to the directory containing this JSON file."
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["releaseSmoke"],
      "properties": {
        "releaseSmoke": {
          "type": "object",
          "additionalProperties": false,
          "required": ["byExtension"],
          "properties": {
            "byExtension": {
              "type": "object",
              "additionalProperties": false,
              "required": ["pmx", "pmd", "vmd", "vpd"],
              "properties": {
                "pmx": {
                  "$ref": "#/$defs/fixtureMap",
                  "description": "PMX fixture paths keyed by arbitrary names such as pmx001 or oneBoneCube."
                },
                "pmd": {
                  "$ref": "#/$defs/fixtureMap",
                  "description": "PMD fixture paths keyed by arbitrary names such as pmd001."
                },
                "vmd": {
                  "$ref": "#/$defs/fixtureMap",
                  "description": "VMD fixture paths keyed by arbitrary names such as vmd001 or walkMotion."
                },
                "vpd": {
                  "$ref": "#/$defs/fixtureMap",
                  "description": "VPD fixture paths keyed by arbitrary names such as vpd001."
                }
              }
            }
          }
        },
        "playbackSmoke": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cases"],
          "properties": {
            "cases": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/playbackSmokeCase"
              },
              "description": "Optional local runtime playback comparisons against native nanoem oracle dumps."
            }
          }
        }
      }
    },
    "description": {
      "type": "string",
      "description": "Optional human-readable notes about the inventory."
    }
  },
  "$defs": {
    "relativeFilePath": {
      "type": "string",
      "minLength": 1,
      "description": "A file path resolved from basePath. Relative paths are recommended for portable inventories."
    },
    "fixtureMap": {
      "type": "object",
      "description": "Map of arbitrary fixture keys to file paths.",
      "propertyNames": {
        "minLength": 1
      },
      "patternProperties": {
        "^.+$": {
          "$ref": "#/$defs/relativeFilePath"
        }
      },
      "additionalProperties": false
    },
    "playbackSmokeCase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "model",
        "motion",
        "oracle",
        "oracleKind",
        "frames",
        "watchBones"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "$ref": "#/$defs/playbackSmokeModelRef"
        },
        "motion": {
          "$ref": "#/$defs/playbackSmokeMotionRef"
        },
        "oracle": {
          "$ref": "#/$defs/relativeFilePath",
          "description": "Path to a gitignored native nanoem oracle JSON, resolved from basePath."
        },
        "oracleKind": {
          "type": "string",
          "const": "native-nanoem-runtime-dump"
        },
        "stage": {
          "type": "string",
          "enum": ["vmdInterpolation", "appendTransform", "ik", "physics"],
          "default": "physics"
        },
        "frames": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "number"
          }
        },
        "watchBones": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "matrixEpsilon": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 0.0001
        },
        "morphEpsilon": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 0.0001
        }
      }
    },
    "playbackSmokeModelRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["extension", "key"],
      "properties": {
        "extension": {
          "type": "string",
          "enum": ["pmx", "pmd"]
        },
        "key": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "playbackSmokeMotionRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key"],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
