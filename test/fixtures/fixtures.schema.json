{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./fixtures.schema.json",
  "title": "three-mmd-loader fixture inventory",
  "description": "Inventory of fixture files used by three-mmd-loader smoke checks.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "paths"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional JSON Schema URI for editor tooling."
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "Fixture inventory schema version."
    },
    "basePath": {
      "type": "string",
      "default": ".",
      "description": "Base directory for fixture entries, resolved relative to the directory containing this JSON file."
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["releaseSmoke"],
      "properties": {
        "releaseSmoke": {
          "type": "object",
          "additionalProperties": false,
          "required": ["byExtension"],
          "properties": {
            "byExtension": {
              "type": "object",
              "additionalProperties": false,
              "required": ["pmx", "pmd", "vmd", "vpd"],
              "properties": {
                "pmx": {
                  "$ref": "#/$defs/fixtureMap",
                  "description": "PMX fixture paths keyed by arbitrary names such as pmx001 or oneBoneCube."
                },
                "pmd": {
                  "$ref": "#/$defs/fixtureMap",
                  "description": "PMD fixture paths keyed by arbitrary names such as pmd001."
                },
                "vmd": {
                  "$ref": "#/$defs/fixtureMap",
                  "description": "VMD fixture paths keyed by arbitrary names such as vmd001 or walkMotion."
                },
                "cameraVmd": {
                  "$ref": "#/$defs/fixtureMap",
                  "description": "Optional camera-only VMD paths for viewer camera import, kept out of motion smoke checks."
                },
                "backgroundPmx": {
                  "$ref": "#/$defs/fixtureMap",
                  "description": "Optional PMX background or stage paths for viewer background import, kept out of model smoke checks."
                },
                "backgroundPmd": {
                  "$ref": "#/$defs/fixtureMap",
                  "description": "Optional PMD background or stage paths for viewer background import, kept out of model smoke checks."
                },
                "vpd": {
                  "$ref": "#/$defs/fixtureMap",
                  "description": "VPD fixture paths keyed by arbitrary names such as vpd001."
                },
                "wav": {
                  "$ref": "#/$defs/fixtureMap",
                  "description": "Optional WAV audio paths keyed by arbitrary names such as wav001."
                },
                "mp3": {
                  "$ref": "#/$defs/fixtureMap",
                  "description": "Optional MP3 audio paths keyed by arbitrary names such as mp3001."
                },
                "ogg": {
                  "$ref": "#/$defs/fixtureMap",
                  "description": "Optional OGG audio paths keyed by arbitrary names such as ogg001."
                }
              }
            }
          }
        },
        "playbackSmoke": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cases"],
          "properties": {
            "cases": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/playbackSmokeCase"
              },
              "description": "Optional local runtime playback cases for developer-only stability checks."
            }
          }
        }
      }
    },
    "description": {
      "type": "string",
      "description": "Optional human-readable notes about the inventory."
    }
  },
  "$defs": {
    "relativeFilePath": {
      "type": "string",
      "minLength": 1,
      "description": "A file path resolved from basePath. Relative paths are recommended for portable inventories."
    },
    "fixtureMap": {
      "type": "object",
      "description": "Map of arbitrary fixture keys to file paths.",
      "propertyNames": {
        "minLength": 1
      },
      "patternProperties": {
        "^.+$": {
          "$ref": "#/$defs/relativeFilePath"
        }
      },
      "additionalProperties": false
    },
    "playbackSmokeCase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "model",
        "motion",
        "frames",
        "watchBones"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "$ref": "#/$defs/playbackSmokeModelRef"
        },
        "motion": {
          "$ref": "#/$defs/playbackSmokeMotionRef"
        },
        "background": {
          "$ref": "#/$defs/playbackSmokeBackgroundRef",
          "description": "Optional background fixture to load with the viewer preset."
        },
        "camera": {
          "$ref": "#/$defs/playbackSmokeCameraRef",
          "description": "Optional camera VMD fixture to load with the viewer preset."
        },
        "audio": {
          "$ref": "#/$defs/playbackSmokeAudioRef",
          "description": "Optional audio fixture to load with the viewer preset."
        },
        "audioOffsetFrame": {
          "type": "number",
          "description": "Optional audio delay offset in MMD frames. Positive values delay audio relative to the motion."
        },
        "oracle": {
          "$ref": "#/$defs/relativeFilePath",
          "description": "Optional path to a gitignored local comparison artifact, resolved from basePath."
        },
        "oracleKind": {
          "type": "string",
          "minLength": 1
        },
        "regressionPurpose": {
          "type": "string",
          "minLength": 1,
          "description": "Optional local-only note describing why a playback case is kept as regression evidence."
        },
        "regressionTags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Optional local-only tags for routing playback regression cases."
        },
        "stage": {
          "type": "string",
          "enum": ["vmdInterpolation", "appendTransform", "ik", "physics"],
          "default": "physics"
        },
        "frames": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "number"
          }
        },
        "watchBones": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "matrixEpsilon": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 0.0001
        },
        "morphEpsilon": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 0.0001
        },
        "skipReason": {
          "type": "string",
          "minLength": 1,
          "description": "Optional local-only reason to skip a playback case while keeping it documented in the inventory."
        },
        "skipCategory": {
          "type": "string",
          "enum": ["runtime-bug", "oracle-limitation", "asset-unavailable"],
          "description": "Optional machine-readable category for skipReason triage."
        }
      }
    },
    "playbackSmokeModelRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["extension", "key"],
      "properties": {
        "extension": {
          "type": "string",
          "enum": ["pmx", "pmd"]
        },
        "key": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "playbackSmokeMotionRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key"],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "playbackSmokeBackgroundRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["extension", "key"],
      "properties": {
        "extension": {
          "type": "string",
          "enum": ["backgroundPmx", "backgroundPmd"]
        },
        "key": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "playbackSmokeCameraRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key"],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "playbackSmokeAudioRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["extension", "key"],
      "properties": {
        "extension": {
          "type": "string",
          "enum": ["wav", "mp3", "ogg"]
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "offsetFrame": {
          "type": "number",
          "description": "Optional audio delay offset in MMD frames for this preset audio reference."
        }
      }
    }
  }
}
