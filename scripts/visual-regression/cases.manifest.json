{
  "version": 1,
  "note": "Initial baselines are for regression detection only; they are not proof of MMD/MMM/nanoem visual equivalence. A separate reference set can be added later.",
  "render": {
    "resolution": { "width": 512, "height": 512 },
    "pixelRatio": 1,
    "camera": {
      "type": "OrthographicCamera",
      "left": -1.6,
      "right": 1.6,
      "top": 1.6,
      "bottom": -1.6,
      "near": 0.1,
      "far": 20,
      "position": [0, 0, 5],
      "target": [0, 0, 0]
    },
    "background": "#d8dde4",
    "colorSpace": "SRGBColorSpace",
    "toneMapping": "NoToneMapping",
    "lights": {
      "ambient": { "color": "#ffffff", "intensity": 1.4 },
      "directional": { "color": "#ffffff", "intensity": 2.2, "position": [2.5, 3.5, 4] }
    }
  },
  "cases": [
    {
      "id": "diffuse-sphere",
      "features": ["diffuse", "lighting"],
      "thresholds": { "mean": 0.015, "p95": 0.06 },
      "geometry": { "kind": "sphere", "radius": 0.9, "widthSegments": 64, "heightSegments": 32 },
      "material": { "kind": "standard", "color": "#4f8fd9", "roughness": 0.65, "metalness": 0 },
      "note": "Baseline captures the current diffuse color and fixed-light response for regression detection only."
    },
    {
      "id": "textured-sphere",
      "features": ["texture", "uv"],
      "thresholds": { "mean": 0.015, "p95": 0.06 },
      "geometry": { "kind": "sphere", "radius": 0.9, "widthSegments": 64, "heightSegments": 32 },
      "material": { "kind": "standard", "texturePattern": "checker", "roughness": 0.7, "metalness": 0 },
      "note": "Baseline captures current spherical UV texture sampling for regression detection only."
    },
    {
      "id": "uv-orientation-plane",
      "features": ["texture", "uv", "orientation"],
      "thresholds": { "mean": 0.015, "p95": 0.06 },
      "geometry": { "kind": "plane", "width": 1.9, "height": 1.9 },
      "material": { "kind": "standard", "texturePattern": "uv-orientation", "side": "double", "roughness": 0.8 },
      "note": "Baseline captures current plane UV orientation and V-axis behavior for regression detection only."
    },
    {
      "id": "toon-sphere",
      "features": ["toon", "toon-ramp", "lighting"],
      "thresholds": { "mean": 0.015, "p95": 0.06 },
      "geometry": { "kind": "sphere", "radius": 0.9, "widthSegments": 64, "heightSegments": 32 },
      "material": { "kind": "toon", "color": "#f0a23a", "toonRamp": "three-step-warm" },
      "note": "Baseline captures current synthetic toon ramp behavior for regression detection only."
    },
    {
      "id": "sphere-multiply",
      "features": ["sphere-texture", "multiply", "lighting"],
      "thresholds": { "mean": 0.015, "p95": 0.06 },
      "geometry": { "kind": "sphere", "radius": 0.9, "widthSegments": 64, "heightSegments": 32 },
      "material": { "kind": "sphere-texture", "color": "#78a7dd", "sphereMode": "multiply", "texturePattern": "radial-sphere" },
      "note": "Baseline captures current synthetic sphere texture multiply behavior for regression detection only."
    },
    {
      "id": "sphere-add",
      "features": ["sphere-texture", "add", "lighting"],
      "thresholds": { "mean": 0.015, "p95": 0.06 },
      "geometry": { "kind": "sphere", "radius": 0.9, "widthSegments": 64, "heightSegments": 32 },
      "material": { "kind": "sphere-texture", "color": "#7eb36a", "sphereMode": "add", "texturePattern": "radial-sphere" },
      "note": "Baseline captures current synthetic sphere texture add behavior for regression detection only."
    },
    {
      "id": "alpha-cutout-plane",
      "features": ["alpha", "alpha-test", "texture"],
      "thresholds": { "mean": 0.015, "p95": 0.06 },
      "geometry": { "kind": "plane", "width": 1.9, "height": 1.9 },
      "material": { "kind": "standard", "texturePattern": "cutout", "alphaMode": "cutout", "alphaTest": 0.5, "side": "double", "roughness": 0.8 },
      "note": "Baseline captures current alphaTest cutout behavior for regression detection only."
    },
    {
      "id": "alpha-blend-overlap",
      "features": ["alpha", "blend", "transparent-ordering"],
      "thresholds": { "mean": 0.015, "p95": 0.06 },
      "geometry": { "kind": "overlap-planes", "width": 1.55, "height": 1.55 },
      "material": { "kind": "overlap-blend", "alphaMode": "blend", "opacity": 0.58 },
      "note": "Baseline captures current transparent overlap behavior for regression detection only."
    },
    {
      "id": "render-order-overlap",
      "features": ["render-order", "alpha", "transparent-ordering"],
      "thresholds": { "mean": 0.015, "p95": 0.06 },
      "geometry": { "kind": "overlap-planes", "width": 1.55, "height": 1.55 },
      "material": { "kind": "overlap-render-order", "alphaMode": "blend", "opacity": 0.62, "renderOrder": [20, 10] },
      "note": "Baseline captures current explicit material render order behavior for regression detection only."
    },
    {
      "id": "outline-sphere",
      "features": ["outline", "expansion", "material-state"],
      "thresholds": { "mean": 0.015, "p95": 0.06 },
      "geometry": { "kind": "outline-sphere", "radius": 0.9, "widthSegments": 64, "heightSegments": 32 },
      "material": { "kind": "outline", "color": "#f3c247", "outlineColor": "#141820", "outlineWidth": 0.08, "roughness": 0.55, "metalness": 0 },
      "note": "Baseline captures current outline expansion and back-side outline material state for regression detection only."
    }
  ]
}
