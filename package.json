{
  "name": "@yohawing/three-mmd-loader",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/yohawing/three-mmd-loader.git"
  },
  "homepage": "https://github.com/yohawing/three-mmd-loader#readme",
  "bugs": {
    "url": "https://github.com/yohawing/three-mmd-loader/issues"
  },
  "keywords": [
    "three",
    "threejs",
    "mmd",
    "mikumikudance",
    "pmx",
    "pmd",
    "vmd",
    "vpd",
    "loader",
    "animation"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./parser": {
      "types": "./dist/parser/index.d.ts",
      "default": "./dist/parser/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./three": {
      "types": "./dist/three/index.d.ts",
      "default": "./dist/three/index.js"
    },
    "./physics": {
      "types": "./dist/physics/index.d.ts",
      "default": "./dist/physics/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-mmd-assets.mjs",
    "dev": "npm run build && node scripts/serve-example-viewer.mjs",
    "example:viewer": "npm run dev",
    "check:fixtures": "node scripts/check-fixtures.mjs",
    "check:fixtures:physics": "node scripts/check-fixtures.mjs --physics",
    "generate:fixtures:minimal-pmx": "node scripts/fixtures/generate-minimal-pmx.mjs",
    "render:visual": "node scripts/visual-regression/render-cases.mjs",
    "render:visual:baseline": "node scripts/visual-regression/render-cases.mjs --mode baseline",
    "render:visual:real-models": "npm run build && node scripts/visual-regression/render-real-models.mjs",
    "render:visual:real-models:baseline": "npm run build && node scripts/visual-regression/render-real-models.mjs --mode baseline",
    "snapshot:real-models:rest-pose": "npm run build && node scripts/visual-regression/snapshot-real-models-rest-pose.mjs",
    "snapshot:real-models:rest-pose:baseline": "npm run build && node scripts/visual-regression/snapshot-real-models-rest-pose.mjs --mode baseline",
    "compare:real-models:rest-pose": "node scripts/visual-regression/compare-real-models-rest-pose.mjs",
    "visual:report": "node scripts/visual-regression/compute-metrics.mjs",
    "visual:report:real-models": "node scripts/visual-regression/compute-metrics.mjs --profile real-models",
    "smoke:dist": "node scripts/dist-export-smoke.mjs",
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "ammo.js": "^0.0.10"
  },
  "peerDependencies": {
    "three": "^0.176.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.15.3",
    "@types/three": "^0.176.0",
    "eslint": "^9.26.0",
    "pngjs": "^7.0.0",
    "three": "^0.176.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vitest": "^3.1.3"
  },
  "files": [
    "dist"
  ]
}
